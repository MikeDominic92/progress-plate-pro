# Supabase Configuration
# Get these values from your Supabase project settings:
# https://app.supabase.com/project/_/settings/api
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key-here

# Auto-authentication password for default user (Kara)
# Used to automatically sign in without showing a login screen
VITE_AUTO_AUTH_PASSWORD=KaraFitness2024!

# Gemini API Key (used by Netlify serverless functions)
GEMINI_API_KEY=your-gemini-api-key-here
